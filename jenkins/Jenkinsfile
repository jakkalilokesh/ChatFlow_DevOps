pipeline {
    agent any

    environment {
        AWS_REGION       = 'us-east-1'
        AWS_ACCOUNT_ID   = credentials('aws-account-id')
        ECR_REGISTRY     = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_TAG        = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        PROJECT          = 'chat-app'
        KUBECONFIG       = credentials('kubeconfig')
        SERVICES         = 'frontend auth-service chat-service user-service notification-service'
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    currentBuild.description = "Branch: ${GIT_BRANCH} | Commit: ${GIT_COMMIT.take(7)}"
                }
            }
        }

        stage('Set Build Info') {
            steps {
                script {
                    def commit = sh(script: 'git log -1 --pretty=format:"%s by %an"', returnStdout: true).trim()
                    currentBuild.description = "Branch: ${GIT_BRANCH} | ${commit}"
                    echo "Building image tag: ${IMAGE_TAG}"
                }
            }
        }





        stage('Build Docker Images') {
            steps {
                script {
                    echo "Building Frontend..."
                    sh "docker build -t ${PROJECT}-frontend:${IMAGE_TAG} ./frontend/"

                    echo "Building Auth Service..."
                    sh "docker build -t ${PROJECT}-auth-service:${IMAGE_TAG} ./auth-service/"

                    echo "Building Chat Service..."
                    sh "docker build -t ${PROJECT}-chat-service:${IMAGE_TAG} ./chat-service/"

                    echo "Building User Service..."
                    sh "docker build -t ${PROJECT}-user-service:${IMAGE_TAG} ./user-service/"

                    echo "Building Notification Service..."
                    sh "docker build -t ${PROJECT}-notification-service:${IMAGE_TAG} ./notification-service/"
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    def services = ['frontend', 'auth-service', 'chat-service', 'user-service', 'notification-service']
                    services.each { svc ->
                        sh """
                            docker run --rm \
                              -v /var/run/docker.sock:/var/run/docker.sock \
                              aquasec/trivy:latest image \
                              --exit-code 0 \
                              --severity HIGH,CRITICAL \
                              --no-progress \
                              --format table \
                              ${PROJECT}-${svc}:${IMAGE_TAG} || true
                        """
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    // ECR login
                    sh """
                        aws ecr get-login-password --region ${AWS_REGION} | \
                        docker login --username AWS --password-stdin ${ECR_REGISTRY}
                    """

                    def services = ['frontend', 'auth-service', 'chat-service', 'user-service', 'notification-service']
                    services.each { svc ->
                        def localTag  = "${PROJECT}-${svc}:${IMAGE_TAG}"
                        def remoteTag = "${ECR_REGISTRY}/${PROJECT}-${svc}:${IMAGE_TAG}"
                        def latestTag = "${ECR_REGISTRY}/${PROJECT}-${svc}:latest"

                        sh """
                            docker tag  ${localTag} ${remoteTag}
                            docker tag  ${localTag} ${latestTag}
                            docker push ${remoteTag}
                            docker push ${latestTag}
                        """
                        echo "Pushed ${remoteTag}"
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                branch 'staging'
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/deploy.sh staging ${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Integration Tests') {
            when {
                branch 'staging'
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/health-check.sh staging
                    """
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/deploy.sh production ${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Health Check') {
            when {
                expression { env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main' || env.GIT_BRANCH == 'staging' || env.GIT_BRANCH == 'origin/staging' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        NAMESPACE=\$([ "\${GIT_BRANCH}" = "main" ] || [ "\${GIT_BRANCH}" = "origin/main" ] && echo "production" || echo "staging")
                        bash scripts/health-check.sh \$NAMESPACE
                    """
                }
            }
        }

        stage('Notify') {
            steps {
                script {
                    def namespace = (env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main') ? 'production' : 'staging'
                    echo """
                    ============================================
                    ✅ ChatFlow Deployment Complete!
                    Branch:    ${GIT_BRANCH}
                    Tag:       ${IMAGE_TAG}
                    Namespace: ${namespace}
                    ============================================
                    """
                }
            }
        }
    }

    post {
        failure {
            script {
                echo "❌ Build failed — triggering rollback..."
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        NAMESPACE=\$([ "\${GIT_BRANCH}" = "main" ] || [ "\${GIT_BRANCH}" = "origin/main" ] && echo "production" || echo "staging")
                        bash scripts/rollback.sh \$NAMESPACE || true
                    """
                }
                echo "⚠️ Email notification skipped: SMTP not configured."
            }
        }
        success {
            script {
                echo "🚀 ChatFlow ${IMAGE_TAG} deployed successfully!"
                echo "⚠️ Email notification skipped: SMTP not configured."
            }
        }
        cleanup {
            sh 'docker image prune -f || true'
            cleanWs()
        }
    }
}
