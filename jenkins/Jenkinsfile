pipeline {
    agent any

    environment {
        AWS_REGION       = 'us-east-1'
        AWS_ACCOUNT_ID   = credentials('aws-account-id')
        ECR_REGISTRY     = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_TAG        = "${BUILD_NUMBER}-${GIT_COMMIT.take(7)}"
        PROJECT          = 'chat-app'
        KUBECONFIG       = credentials('kubeconfig')
        SERVICES         = 'auth-service chat-service user-service notification-service call-service ai-service'
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                script {
                    currentBuild.description = "Branch: ${GIT_BRANCH} | Commit: ${GIT_COMMIT.take(7)}"
                }
            }
        }

        stage('Set Build Info') {
            steps {
                script {
                    def commit = sh(script: 'git log -1 --pretty=format:"%s by %an"', returnStdout: true).trim()
                    currentBuild.description = "Branch: ${GIT_BRANCH} | ${commit}"
                    echo "Building image tag: ${IMAGE_TAG}"
                }
            }
        }





        stage('Build Docker Images') {
            steps {
                script {
                    // NOTE: Frontend is deployed via Vercel (Git integration).
                    // Only backend microservices are built and pushed to ECR.

                    echo "Building Auth Service..."
                    sh "docker build -t ${PROJECT}-auth-service:${IMAGE_TAG} ./auth-service/"

                    echo "Building Chat Service..."
                    sh "docker build -t ${PROJECT}-chat-service:${IMAGE_TAG} ./chat-service/"

                    echo "Building User Service..."
                    sh "docker build -t ${PROJECT}-user-service:${IMAGE_TAG} ./user-service/"

                    echo "Building Notification Service..."
                    sh "docker build -t ${PROJECT}-notification-service:${IMAGE_TAG} ./notification-service/"

                    echo "Building Call Service..."
                    sh "docker build -t ${PROJECT}-call-service:${IMAGE_TAG} ./call-service/"

                    echo "Building AI Service..."
                    sh "docker build -t ${PROJECT}-ai-service:${IMAGE_TAG} ./ai-service/"
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    def services = ['auth-service', 'chat-service', 'user-service', 'notification-service', 'call-service', 'ai-service']
                    services.each { svc ->
                        sh """
                            docker run --rm \
                              -v /var/run/docker.sock:/var/run/docker.sock \
                              -v /var/lib/jenkins/.cache/trivy:/root/.cache/trivy \
                              aquasec/trivy:latest image \
                              --scanners vuln \
                              --exit-code 0 \
                              --severity HIGH,CRITICAL \
                              --no-progress \
                              --format table \
                              ${PROJECT}-${svc}:${IMAGE_TAG} || true
                        """
                    }
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    def cleanRegistry = ECR_REGISTRY.toString().trim().replaceAll("\\s+", "")
                    // ECR login
                    sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${cleanRegistry}"
 
                    def services = ['auth-service', 'chat-service', 'user-service', 'notification-service', 'call-service', 'ai-service']
                    services.each { svc ->
                        // Ensure ECR repo exists (idempotent — safe to call if already exists)
                        sh """
                            aws ecr describe-repositories --repository-names ${PROJECT}-${svc} --region ${AWS_REGION} 2>/dev/null || \
                            aws ecr create-repository --repository-name ${PROJECT}-${svc} --region ${AWS_REGION} \
                                --image-scanning-configuration scanOnPush=true \
                                --encryption-configuration encryptionType=AES256
                        """
 
                        def localTag  = "${PROJECT}-${svc}:${IMAGE_TAG}"
                        def remoteTag = "${cleanRegistry}/${PROJECT}-${svc}:${IMAGE_TAG}"
                        def latestTag = "${cleanRegistry}/${PROJECT}-${svc}:latest"
 
                        sh """
                            docker tag  ${localTag} ${remoteTag}
                            docker tag  ${localTag} ${latestTag}
                            docker push ${remoteTag}
                            docker push ${latestTag}
                        """
                        echo "Pushed ${remoteTag}"
                    }
                }
            }
        }

        stage('Deploy to Staging') {
            when {
                branch 'staging'
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/deploy.sh staging ${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Integration Tests') {
            when {
                branch 'staging'
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/health-check.sh staging
                    """
                }
            }
        }

        stage('Deploy to Production') {
            when {
                expression { env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        bash scripts/deploy.sh production ${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Health Check') {
            when {
                expression { env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main' || env.GIT_BRANCH == 'staging' || env.GIT_BRANCH == 'origin/staging' }
            }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        NAMESPACE=\$([ "\${GIT_BRANCH}" = "main" ] || [ "\${GIT_BRANCH}" = "origin/main" ] && echo "production" || echo "staging")
                        bash scripts/health-check.sh \$NAMESPACE
                    """
                }
            }
        }

        stage('Notify') {
            steps {
                script {
                    def namespace = (env.GIT_BRANCH == 'main' || env.GIT_BRANCH == 'origin/main') ? 'production' : 'staging'
                    echo """
                    ============================================
                    ✅ ChatFlow Deployment Complete!
                    Branch:    ${GIT_BRANCH}
                    Tag:       ${IMAGE_TAG}
                    Namespace: ${namespace}
                    ============================================
                    """
                }
            }
        }
    }

    post {
        failure {
            script {
                echo "❌ Build failed — triggering rollback..."
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG_FILE')]) {
                    sh """
                        export KUBECONFIG=\$KUBECONFIG_FILE
                        NAMESPACE=\$([ "\${GIT_BRANCH}" = "main" ] || [ "\${GIT_BRANCH}" = "origin/main" ] && echo "production" || echo "staging")
                        bash scripts/rollback.sh \$NAMESPACE || true
                    """
                }
                try {
                    mail to: 'lokesh.j.g13cs@gmail.com',
                         subject: "❌ ChatFlow Build Failed: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                         body: "The ChatFlow deployment pipeline failed and triggered a rollback.\n\nPlease check the console output here: ${env.BUILD_URL}"
                } catch (Exception e) {
                    echo "⚠️ Failed to send failure email notification: ${e.message}"
                }
            }
        }
        success {
            script {
                echo "🚀 ChatFlow ${IMAGE_TAG} deployed successfully!"
                try {
                    mail to: 'lokesh.j.g13cs@gmail.com',
                         subject: "✅ ChatFlow Build Succeeded: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                         body: "The ChatFlow deployment pipeline completed successfully!\n\nImage Tag: ${IMAGE_TAG}\nView the build logs here: ${env.BUILD_URL}"
                } catch (Exception e) {
                    echo "⚠️ Failed to send success email notification: ${e.message}"
                }
            }
        }
        cleanup {
            sh 'docker image prune -f || true'
            cleanWs()
        }
    }
}
