# ============================================================
# ChatFlow — Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to git!
# ============================================================

# ========================
# General
# ========================
NODE_ENV=development
COMPOSE_PROJECT_NAME=chatflow

# ========================
# Auth Service (Port 3001)
# ========================
AUTH_SERVICE_PORT=3001
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-at-least-64-characters-long-change-this
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

# ========================
# Chat Service (Port 3002)
# ========================
CHAT_SERVICE_PORT=3002

# ========================
# User Service (Port 3003)
# ========================
USER_SERVICE_PORT=3003

# ========================
# Notification Service (Port 3004)
# ========================
NOTIFICATION_SERVICE_PORT=3004

# ========================
# Frontend (Port 3000)
# ========================
REACT_APP_API_URL=http://localhost
REACT_APP_WS_URL=ws://localhost
REACT_APP_ENV=development

# ========================
# PostgreSQL
# ========================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chatflow
DB_USER=chatflow_user
DB_PASSWORD=your-strong-postgres-password-change-this
POSTGRES_DB=chatflow
POSTGRES_USER=chatflow_user
POSTGRES_PASSWORD=your-strong-postgres-password-change-this

# ========================
# MongoDB
# ========================
MONGO_URI=mongodb://chatflow_user:your-mongo-password@mongo:27017/chatflow?authSource=admin
MONGO_INITDB_ROOT_USERNAME=chatflow_user
MONGO_INITDB_ROOT_PASSWORD=your-mongo-password-change-this
MONGO_INITDB_DATABASE=chatflow

# ========================
# Redis
# ========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password-change-this

# ========================
# AWS Configuration
# ========================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ========================
# S3
# ========================
S3_BUCKET_NAME=chatflow-app-backups-your-unique-suffix
S3_AVATARS_BUCKET=chatflow-avatars-your-unique-suffix

# ========================
# Monitoring
# ========================
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password-change-this
PROMETHEUS_RETENTION=15d

# ========================
# SMTP (for 2FA backup codes + Alertmanager)
# ========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
ALERT_EMAIL_FROM=alerts@chatflow.example.com
ALERT_EMAIL_TO=admin@chatflow.example.com

# ========================
# Call Service (WebRTC / mediasoup)
# ========================
CALL_SERVICE_PORT=3005
ANNOUNCED_IP=127.0.0.1
# UDP port range for mediasoup workers
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# ========================
# MinIO (File Storage)
# ========================
MINIO_ROOT_USER=chatflow_admin
MINIO_ROOT_PASSWORD=your-strong-minio-password-change-this
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_ATTACHMENTS=attachments
MINIO_BUCKET_VOICE_NOTES=voice-notes

# ========================
# Meilisearch (Full-Text Search)
# ========================
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=chatflow-meili-master-key-change-this

# ========================
# LibreTranslate (Message Translation)
# ========================
LIBRETRANSLATE_URL=http://libretranslate:5000

# ========================
# 2FA / TOTP
# ========================
TOTP_ISSUER=ChatFlow

# ========================
# Web Push Notifications (VAPID)
# ========================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@chatflow.example.com

