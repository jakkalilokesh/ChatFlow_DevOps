# ─────────────────────────────────────────────────────────────
# ChatFlow Frontend — Vercel Environment Variables
#
# Copy this to your Vercel project settings:
# Dashboard → Project → Settings → Environment Variables
#
# Or use the Vercel CLI:
#   vercel env add REACT_APP_API_URL
# ─────────────────────────────────────────────────────────────

# Points to your AWS K8s ingress (the nginx ingress external IP / domain)
# Example: https://api.chatflow.app  or  http://13.54.190.60
REACT_APP_API_URL=https://your-k8s-ingress-domain.com

# WebSocket server — usually same host as API
REACT_APP_SOCKET_URL=https://your-k8s-ingress-domain.com

# Google OAuth Client ID (public — safe to expose in frontend)
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Disable source maps in production build (keeps bundle smaller)
GENERATE_SOURCEMAP=false
